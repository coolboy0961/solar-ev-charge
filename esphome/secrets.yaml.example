# ESPHome Tesla BLE Secrets
# Copy this file to secrets.yaml and fill in your actual values
#   cp secrets.yaml.example secrets.yaml

wifi_ssid: "your_wifi_ssid"
wifi_password: "your_wifi_password"
# Fallback AP password (used by PedroKTFC base.yml)
wifi_hotspot_password: "your_hotspot_password"

# Tesla vehicle info
tesla_vin: "your_tesla_vin"
# BLE MAC address - discovered using tesla_ble_listener package
tesla_ble_mac: "XX:XX:XX:XX:XX:XX"
# PedroKTFC fork uses this key name
ble_mac_address: "XX:XX:XX:XX:XX:XX"

# ESPHome API encryption key (generate with below command)
#   python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
api_encryption_key: "your_api_encryption_key"

# OTA password
ota_password: "your_ota_password"
